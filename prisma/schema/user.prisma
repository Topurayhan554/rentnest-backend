model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role

  activeStatus ActiveStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  properties     Property[]      @relation("LandlordProperties")
  rentalRequests RentalRequest[] @relation("TenantRentalRequests")
  reviews        Review[]        @relation("TenantReviews")

  @@map("users")
}
